# MacPorts Portfile for Adyton (S21). Source build via the cargo PortGroup.
#
# Two blocks carry release-time values that only exist once a tag is published
# (see docs/RELEASING.md → "MacPorts"); the release workflow fills them:
#   1. `checksums` — of the GitHub source tarball for the tag.
#   2. `cargo.crates` — generated by `port cargo2port Cargo.lock`.

PortSystem          1.0
PortGroup           github 1.0
PortGroup           cargo 1.0

github.setup        Metalnib adyton 0.2.0 v
categories          sysutils
platforms           {darwin any}
# Dual-licensed, user's choice (nested list = OR in MacPorts). Verify nesting
# against the current MacPorts guide before upstream submission.
license             {MIT Apache-2}
maintainers         {@Metalnib openmaintainer}
description         Natural language to shell command, streamed to your prompt
long_description    Adyton turns plain English into shell commands and fixes \
                    failed ones, streamed to your prompt for review and never \
                    executed for you. One static binary; zsh/bash/fish; any \
                    OpenAI-compatible or Anthropic endpoint.
homepage            https://github.com/Metalnib/adyton

# {{RELEASE}} checksums of https://github.com/Metalnib/adyton/archive/v${version}.tar.gz
checksums           rmd160  {{RMD160}} \
                    sha256  {{SHA256}} \
                    size    {{SIZE}}

# {{RELEASE}} generated by: port cargo2port Cargo.lock
cargo.crates \
    {{CARGO_CRATES}}

# Release profile is defined in Cargo.toml; MacPorts builds --release by default.

post-destroot {
    # Shell integration is opt-in by the user (adyton init <shell>); nothing to
    # wire here. The single binary is installed by the cargo PortGroup.
}

notes "
Enable the shell integration by adding one line to your shell rc:
  zsh  ->  eval \"\$(adyton init zsh)\"
  bash ->  eval \"\$(adyton init bash)\"
  fish ->  adyton init fish | source
Then configure a provider: adyton config set-key <profile>
Update MacPorts installs with 'sudo port upgrade adyton' (not 'adyton selfupdate').
"
